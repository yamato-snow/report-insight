# このファイルを `.env` にコピーして使う: cp env.example .env
# （設計文書 08 は `.env.example` を指すが、実装環境の保護ガードによりドット無しで提供）
#
# --- LLM ---
LLM_PROVIDER=fake                  # fake | anthropic
ANTHROPIC_API_KEY=
MODEL_CLASSIFY=claude-haiku-4-5-20251001   # 分類・構造化（Haiku級）
MODEL_GENERATE=claude-sonnet-5             # RAG回答・月次報告書（Sonnet級）
LLM_MAX_CONCURRENCY=4
CONFIDENCE_THRESHOLD=0.85          # 未満は needs_review へ

# --- 埋め込み ---
EMBEDDING_MODEL=intfloat/multilingual-e5-large   # fastembed（1024次元）
EMBEDDING_DIM=1024

# --- AWS（ローカルは LocalStack） ---
AWS_ENDPOINT_URL=http://localstack:4566
AWS_REGION=ap-northeast-1
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
S3_INBOX_BUCKET=report-inbox
SQS_QUEUE_URL=http://localstack:4566/000000000000/report-queue

# --- DB / 通知 ---
DATABASE_URL=postgresql+asyncpg://app:app@db:5432/report_insight
SLACK_WEBHOOK_URL=http://webhook-mock:9000/webhook

# --- 実行 ---
LOG_LEVEL=INFO
